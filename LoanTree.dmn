<?xml version='1.0' encoding='utf-8'?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd" id="definitions_1" name="Loan Decision Model" namespace="http://example.org/dmn"><decision id="decision_1" name="Loan Approval"><decisionTable id="decisionTable_1" hitPolicy="UNIQUE"><input id="in_1"><inputExpression id="expr_2" typeRef="double"><text>Age</text></inputExpression></input><input id="in_3"><inputExpression id="expr_4" typeRef="double"><text>Income</text></inputExpression></input><output id="out_5" name="Loan_Approval" typeRef="string" /><rule id="rule_6"><inputEntry id="cell_7"><text>&lt;= 62.50</text></inputEntry><inputEntry id="cell_8"><text>&lt;= 31847.00</text></inputEntry><outputEntry id="outc_9"><text>Reject</text></outputEntry></rule><rule id="rule_10"><inputEntry id="cell_11"><text>&lt;= 18.50</text></inputEntry><inputEntry id="cell_12"><text>&gt; 31847.00</text></inputEntry><outputEntry id="outc_13"><text>Reject</text></outputEntry></rule><rule id="rule_14"><inputEntry id="cell_15"><text>&gt; 18.50</text></inputEntry><inputEntry id="cell_16"><text>&gt; 31847.00</text></inputEntry><outputEntry id="outc_17"><text>Approve</text></outputEntry></rule><rule id="rule_18"><inputEntry id="cell_19"><text>&gt; 62.50</text></inputEntry><inputEntry id="cell_20"><text>-</text></inputEntry><outputEntry id="outc_21"><text>Reject</text></outputEntry></rule></decisionTable></decision></definitions>